NODE_ENV=production
HOST=127.0.0.1
PORT=8787
PUBLIC_BASE_URL=https://your-platform.example.com

# Local durable storage
STORAGE_DRIVER=sqlite
SQLITE_FILE=./data/itera.sqlite

# Third-party AI model API. Use any OpenAI-compatible chat completions provider.
# Examples:
# DeepSeek: AI_API_BASE_URL=https://api.deepseek.com, AI_MODEL=deepseek-v4-flash
# OpenRouter: AI_API_BASE_URL=https://openrouter.ai/api/v1, AI_MODEL=openai/gpt-4.1-mini
# Qwen DashScope compatible mode: use the provider's OpenAI-compatible base URL and model name.
AI_PROVIDER=openai-compatible
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
AI_TEMPERATURE=0.2
# Optional local proxy for Clash/VPN users, for example: http://127.0.0.1:7890
AI_HTTP_PROXY=

# GitHub App. Use GITHUB_TOKEN only as a fallback for early testing.
GITHUB_APP_SLUG=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_APP_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
# Keep false until branch protection, CI, and rollback are ready for real customer repositories.
GITHUB_AUTO_MERGE_ENABLED=false

# Isolated production sandbox provider.
SANDBOX_MODE=isolated-provider
SANDBOX_PROVIDER=external-http-provider
SANDBOX_PROVIDER_URL=
SANDBOX_PROVIDER_TOKEN=
SANDBOX_PROVIDER_PRIVATE_NETWORK=false
VERCEL_SANDBOX_TOKEN=
SANDBOX_PROVIDER_RUNTIME=local-process
SANDBOX_PROVIDER_PORT=8794

# Stripe billing. Choose either Payment Links or Checkout Session price IDs.
STRIPE_PAYMENT_LINK_PRO=
STRIPE_PAYMENT_LINK_SCALE=
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
STRIPE_WEBHOOK_SECRET=
STRIPE_CUSTOMER_PORTAL_URL=
