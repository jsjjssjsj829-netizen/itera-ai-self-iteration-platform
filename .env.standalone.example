NODE_ENV=production
HOST=127.0.0.1
PORT=8787
PUBLIC_BASE_URL=http://127.0.0.1:8787

# Durable local storage. This works without Codex.
STORAGE_DRIVER=sqlite
SQLITE_FILE=./data/itera.sqlite
SIGNAL_RATE_LIMIT_PER_MINUTE=120

# Third-party AI model API. Required for real AI analysis and code reasoning without Codex.
AI_PROVIDER=openai-compatible
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
AI_TEMPERATURE=0.2
# Optional local proxy for Clash/VPN users, for example: http://127.0.0.1:7890
AI_HTTP_PROXY=

# Optional: allow local customer repositories under this folder.
# The start-standalone.bat script sets this to the parent outputs folder by default.
ITERA_ALLOWED_REPO_ROOT=

# Optional real integrations. Leave empty for standalone local mode.
GITHUB_APP_SLUG=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_APP_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
GITHUB_AUTO_MERGE_ENABLED=false

SANDBOX_PROVIDER_URL=
SANDBOX_PROVIDER_TOKEN=
SANDBOX_PROVIDER_PRIVATE_NETWORK=false

STRIPE_PAYMENT_LINK_PRO=
STRIPE_PAYMENT_LINK_SCALE=
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
STRIPE_WEBHOOK_SECRET=
STRIPE_CUSTOMER_PORTAL_URL=
